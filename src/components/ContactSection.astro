<style>
  .contact {
    padding: clamp(5rem, 10vh, 8rem) clamp(1.5rem, 8vw, 7rem);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
    max-width: 100%;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .label-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .section-label span:last-child {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  .contact-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .contact-title em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--ink-soft);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-top: 0.5rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    border: 1px solid color-mix(in oklch, var(--ink) 10%, transparent);
    background: var(--paper-warm);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
    color: var(--ink);
  }

  .contact-item:hover {
    border-color: color-mix(in oklch, var(--accent) 30%, transparent);
    background: var(--paper);
    transform: translateX(4px);
  }

  .contact-item-featured {
    background: var(--paper-warm);
  }

  .contact-item-featured:hover {
    background: var(--paper);
  }

  .contact-item-icon {
    color: var(--accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .contact-item-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .contact-item-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .contact-item-value {
    font-size: 0.9375rem;
    color: var(--ink);
  }

  .contact-arrow {
    color: var(--ink-muted);
    flex-shrink: 0;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .contact-item:hover .contact-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
