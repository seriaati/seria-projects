---
import type { Project } from "../data/projects";
import { allTags } from "../data/projects";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="filter-root">
  <div class="filter-bar">
    <div class="search-wrap">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="project-search"
        type="search"
        placeholder="Search projects…"
        autocomplete="off"
        aria-label="Search projects"
        data-i18n-placeholder="projects.searchPlaceholder"
        data-i18n-aria="projects.searchAriaLabel"
      />
    </div>

    <div class="tags-wrap" role="group" aria-label="Filter by tag" data-i18n-aria="projects.filterAriaLabel">
      <button class="tag-btn active" data-tag="all" data-i18n="projects.tagAll">All</button>
      {allTags.map((tag) => (
        <button class="tag-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </div>

  <div class="results-meta" aria-live="polite">
    <span id="results-count" data-count={projects.length}>{projects.length} projects</span>
  </div>

  <div class="projects-grid" id="projects-grid">
    {projects.map((project, i) => (
      <div
        class="project-item"
        data-name={project.name.toLowerCase()}
        data-description={project.description.toLowerCase()}
        data-description-zh-tw={(project.descriptionZhTW ?? project.description).toLowerCase()}
        data-tags={project.tags.join(",")}
      >
        <ProjectCard project={project} index={i} />
      </div>
    ))}
  </div>

  <div class="empty-state" id="empty-state" hidden>
    <p class="empty-title" data-i18n="projects.emptyTitle">No projects found</p>
    <p class="empty-sub" data-i18n="projects.emptySub">Try a different search term or tag.</p>
  </div>
</div>

<script>
  const searchInput = document.getElementById("project-search") as HTMLInputElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const items = document.querySelectorAll<HTMLElement>(".project-item");
  const countEl = document.getElementById("results-count")!;
  const emptyState = document.getElementById("empty-state")!;
  const grid = document.getElementById("projects-grid")!;

  let activeTag = "all";
  let searchQuery = "";

  function filter() {
    let visible = 0;
    let visibleIndex = 0;
    const locale = (window as any).__currentLocale || localStorage.getItem("locale") || "en";

    items.forEach((item) => {
      const name = item.dataset.name ?? "";
      const desc = locale === "zh-TW"
        ? (item.dataset.descriptionZhTw ?? item.dataset.description ?? "")
        : (item.dataset.description ?? "");
      const tags = item.dataset.tags ?? "";

      const matchesTag = activeTag === "all" || tags.split(",").includes(activeTag);
      const matchesSearch =
        searchQuery === "" ||
        name.includes(searchQuery) ||
        desc.includes(searchQuery) ||
        tags.includes(searchQuery);

      const show = matchesTag && matchesSearch;
      item.hidden = !show;
      if (show) {
        visible++;
        const card = item.querySelector<HTMLElement>(".project-card");
        if (card) {
          card.style.setProperty("--i", String(visibleIndex));
        }
        visibleIndex++;
      }
    });

    countEl.setAttribute("data-count", String(visible));
    countEl.textContent = locale === "zh-TW"
      ? `${visible} 個專案`
      : `${visible} project${visible !== 1 ? "s" : ""}`;
    emptyState.hidden = visible > 0;
    grid.hidden = visible === 0;
  }

  searchInput.addEventListener("input", () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    filter();
  });

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeTag = btn.dataset.tag ?? "all";
      tagButtons.forEach((b) => b.classList.toggle("active", b === btn));
      filter();
    });
  });
</script>

<style>
  .filter-root {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .search-wrap {
    position: relative;
    max-width: 420px;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-muted);
    pointer-events: none;
  }

  #project-search {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    background: var(--paper-warm);
    border: 1px solid color-mix(in oklch, var(--ink) 12%, transparent);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s ease;
    appearance: none;
  }

  #project-search::placeholder {
    color: var(--ink-muted);
  }

  #project-search:focus {
    border-color: color-mix(in oklch, var(--accent) 50%, transparent);
  }

  #project-search::-webkit-search-cancel-button {
    appearance: none;
  }

  .tags-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-btn {
    padding: 0.375rem 0.875rem;
    font-family: var(--sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid color-mix(in oklch, var(--ink) 12%, transparent);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .tag-btn:hover {
    border-color: color-mix(in oklch, var(--ink) 30%, transparent);
    color: var(--ink);
  }

  .tag-btn.active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }

  .results-meta {
    font-size: 0.8125rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.5px;
  }

  .empty-state {
    padding: 4rem 0;
    text-align: center;
  }

  .empty-title {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink-soft);
    margin-bottom: 0.5rem;
  }

  .empty-sub {
    font-size: 0.9375rem;
    color: var(--ink-muted);
  }
</style>
