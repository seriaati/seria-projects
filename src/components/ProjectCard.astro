---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  index?: number;
  stars?: number;
}

const { project, index = 0, stars } = Astro.props;
const githubUrl = `https://github.com/seriaati/${project.repo}`;
---

<article class="project-card" style={`--i: ${index}`} data-github={githubUrl}>
  <div
    class="card-link"
    role="link"
    tabindex="0"
    aria-label={`View ${project.name} on GitHub`}
  >
    <div class="card-inner">
      <div class="card-header">
        <div class="card-meta">
          {project.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <div class="card-links">
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View on GitHub"
            class="icon-link github-link"
            onclick="event.stopPropagation()"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          {
            project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Live site"
                class="icon-link"
                onclick="event.stopPropagation()"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <div class="card-body">
        <h3 class="card-title">{project.name}</h3>
        <p
          class="card-description"
          data-description-en={project.description}
          data-description-zh-tw={project.descriptionZhTW ??
            project.description}
        >
          {project.description}
        </p>
        {
          stars !== undefined && stars > 0 && (
            <div class="card-stars">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              <span>{stars.toLocaleString()}</span>
            </div>
          )
        }
      </div>
    </div>
  </div>
</article>

<script>
  if (!document.getElementById("gh-cursor")) {
    const cursor = document.createElement("div");
    cursor.id = "gh-cursor";
    cursor.setAttribute("aria-hidden", "true");
    cursor.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`;
    Object.assign(cursor.style, {
      position: "fixed",
      pointerEvents: "none",
      opacity: "0",
      transition: "opacity 0.15s ease",
      zIndex: "9999",
      width: "2rem",
      height: "2rem",
      display: "flex",
      alignItems: "center",
      justifyContent: "center",
      borderRadius: "50%",
    });
    document.body.appendChild(cursor);

    const applyTheme = () => {
      cursor.style.color = getComputedStyle(document.documentElement)
        .getPropertyValue("--ink")
        .trim();
      cursor.style.background = getComputedStyle(document.documentElement)
        .getPropertyValue("--paper-warm")
        .trim();
      cursor.style.border = `1px solid color-mix(in oklch, ${getComputedStyle(document.documentElement).getPropertyValue("--ink").trim()} 15%, transparent)`;
    };
    applyTheme();

    new MutationObserver(applyTheme).observe(document.documentElement, {
      attributeFilter: ["class"],
    });

    document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
      const githubUrl = card.dataset.github!;
      const link = card.querySelector<HTMLElement>(".card-link");

      // Make the div behave as a link
      link?.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest(".icon-link")) return;
        window.open(githubUrl, "_blank", "noopener,noreferrer");
      });
      link?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          window.open(githubUrl, "_blank", "noopener,noreferrer");
        }
      });

      card.querySelectorAll<HTMLElement>(".icon-link").forEach((iconLink) => {
        iconLink.addEventListener("mouseenter", () => {
          cursor.style.opacity = "0";
        });
        iconLink.addEventListener("mouseleave", () => {
          cursor.style.opacity = "1";
        });
      });

      card.addEventListener("mouseenter", () => {
        cursor.style.opacity = "1";
      });
      card.addEventListener("mouseleave", () => {
        cursor.style.opacity = "0";
      });
      let rafId: number;
      card.addEventListener("mousemove", (e: MouseEvent) => {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          cursor.style.left = `${e.clientX + 14}px`;
          cursor.style.top = `${e.clientY + 14}px`;
        });
      });
    });
  }
</script>

<style>
  .project-card {
    position: relative;
    height: 100%;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    cursor: pointer;
  }

  .card-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border: 1px solid color-mix(in oklch, var(--ink) 10%, transparent);
    background: color-mix(in oklch, var(--paper-warm) 60%, transparent);
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      transform 0.25s ease;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    animation: card-enter 0.6s ease forwards;
    animation-delay: min(calc(var(--i) * 0.05s), 0.4s);
  }

  @keyframes card-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-inner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in oklch, var(--accent-pale) 40%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .project-card:hover .card-inner {
    border-color: color-mix(in oklch, var(--accent) 30%, transparent);
    background: var(--paper-warm);
    transform: translateY(-3px);
  }

  .project-card:hover .card-inner::before {
    opacity: 1;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in oklch, var(--accent) 10%, transparent);
    padding: 0.2rem 0.5rem;
    border: 1px solid color-mix(in oklch, var(--accent) 20%, transparent);
  }

  .card-links {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
    align-self: center;
  }

  .icon-link {
    color: var(--ink-muted);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .icon-link:hover {
    color: var(--ink);
  }

  @media (hover: hover) {
    .github-link {
      display: none;
    }
  }

  .card-body {
    flex: 1;
  }

  .card-title {
    font-family: var(--serif);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .card-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
</style>
