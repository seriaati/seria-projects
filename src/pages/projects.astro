---
import Layout from "../layouts/Layout.astro";
import ProjectsFilter from "../components/ProjectsFilter.astro";
import { projects } from "../data/projects";
import { fetchStars } from "../lib/github";

const starsMap = await fetchStars(projects.map((p) => p.repo));
const sortedProjects = [...projects].sort(
  (a, b) => (starsMap[b.repo] ?? 0) - (starsMap[a.repo] ?? 0),
);
---

<Layout title="Projects — Seria" description="All projects by Seria.">
  <main>
    <div class="page-header">
      <div class="header-inner">
        <div class="header-eyebrow">
          <span class="eyebrow-line"></span>
          <span data-i18n="projects.eyebrow">All work</span>
        </div>
        <h1 class="page-title" data-i18n="projects.title">Projects</h1>
        <p class="page-sub" data-i18n="projects.sub">
          A curated list of things I've built.
        </p>
      </div>
    </div>

    <div class="page-body">
      <ProjectsFilter projects={sortedProjects} starsMap={starsMap} />
    </div>
  </main>
</Layout>

<style>
  main {
    flex: 1;
  }

  .page-header {
    padding: clamp(5rem, 10vh, 7rem) clamp(1.5rem, 8vw, 7rem)
      clamp(3rem, 5vh, 4rem);
    border-bottom: 1px solid color-mix(in oklch, var(--ink) 8%, transparent);
    background: var(--paper-warm);
  }

  .header-inner {
    max-width: 600px;
  }

  .header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .eyebrow-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .header-eyebrow span:last-child {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .page-sub {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .page-body {
    padding: clamp(3rem, 6vh, 5rem) clamp(1.5rem, 8vw, 7rem);
  }
</style>
